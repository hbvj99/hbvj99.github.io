---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="About Me | Vijay Pathak" description="Learn about Vijay Pathak's software engineering background, cloud computing expertise, systems timeline, and key engineering projects.">
  <div class="container">
    <!-- About Hero -->
    <section class="about-hero">
      <h1 class="glow-title">About Me</h1>
      <div class="about-intro card-glass animate-fade-up" style="--delay: 0ms">
        <p>Hello, I'm <strong>Vijay Pathak</strong>, a software engineer specializing in backend systems and cloud infrastructure.</p>
        <p>I have over six years of experience designing and building scalable software systems. My interests include systems engineering, infrastructure, security, open-source development, and cloud automation.</p>
        <div class="about-badges">
          <span class="badge"><i class="fas fa-briefcase"></i> 6+ Years Experience</span>
          <span class="badge"><i class="fas fa-cloud"></i> Cloud Native</span>
          <span class="badge"><i class="fas fa-laptop-code"></i> Open to Work</span>
        </div>
      </div>
    </section>

    <!-- Core Expertise -->
    <section class="section">
      <h2 class="section-title"><i class="fas fa-code"></i> Core Expertise</h2>
      <div class="skills-grid">
        <div class="skills-card card-glass animate-fade-up" style="--delay: 0ms">
          <h4><i class="fas fa-terminal"></i> Languages</h4>
          <div class="skills-list">
            <span class="skill-tag">Python</span>
            <span class="skill-tag">JavaScript / TypeScript</span>
            <span class="skill-tag">Java</span>
            <span class="skill-tag">Bash</span>
          </div>
        </div>

        <div class="skills-card card-glass animate-fade-up" style="--delay: 80ms">
          <h4><i class="fas fa-server"></i> Cloud & Infrastructure</h4>
          <div class="skills-list">
            <span class="skill-tag">AWS</span>
            <span class="skill-tag">Google Cloud</span>
            <span class="skill-tag">Docker</span>
            <span class="skill-tag">CI / CD Pipelines</span>
            <span class="skill-tag">Nginx</span>
            <span class="skill-tag">Linux Systems</span>
          </div>
        </div>

        <div class="skills-card card-glass animate-fade-up" style="--delay: 160ms">
          <h4><i class="fas fa-database"></i> Databases & Caching</h4>
          <div class="skills-list">
            <span class="skill-tag">PostgreSQL</span>
            <span class="skill-tag">MySQL</span>
            <span class="skill-tag">DynamoDB</span>
            <span class="skill-tag">Oracle</span>
            <span class="skill-tag">Redis</span>
          </div>
        </div>

        <div class="skills-card card-glass animate-fade-up" style="--delay: 240ms">
          <h4><i class="fas fa-project-diagram"></i> Architectural Patterns</h4>
          <div class="skills-list">
            <span class="skill-tag">RESTful APIs</span>
            <span class="skill-tag">Microservices</span>
            <span class="skill-tag">Event-Driven Systems</span>
            <span class="skill-tag">Serverless Workflows</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Work Experience Timeline -->
    <section class="section">
      <h2 class="section-title"><i class="fas fa-history"></i> Experience</h2>
      <div class="timeline">
        <div class="timeline-item animate-fade-up" style="--delay: 0ms">
          <div class="timeline-dot"></div>
          <div class="timeline-content card-glass">
            <div class="timeline-header">
              <h3>Software Engineer</h3>
              <span class="timeline-company">OutCode Software</span>
              <span class="timeline-date">Jul 2020 – Present</span>
            </div>
            <p>Led backend and infrastructure development for Salesforce data pipelines, AWS/GCP integrations, AWS Marketplace automation, and AWS IVS live-streaming platforms, including on-premises networking and GraphQL APIs.</p>
          </div>
        </div>

        <div class="timeline-item animate-fade-up" style="--delay: 80ms">
          <div class="timeline-dot"></div>
          <div class="timeline-content card-glass">
            <div class="timeline-header">
              <h3>Software Engineer</h3>
              <span class="timeline-company">Insight Workshop</span>
              <span class="timeline-date">Jul 2020 – Oct 2020</span>
            </div>
            <p>Designed US patent analysis pipelines and built real-time communication systems with Django and Jenkins CI/CD.</p>
          </div>
        </div>

        <div class="timeline-item animate-fade-up" style="--delay: 160ms">
          <div class="timeline-dot"></div>
          <div class="timeline-content card-glass">
            <div class="timeline-header">
              <h3>Software Developer</h3>
              <span class="timeline-company">Datopian</span>
              <span class="timeline-date">Jan 2020 – Mar 2020</span>
            </div>
            <p>Worked with CKAN for Denmark’s national energy transmission system.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Projects Grid -->
    <section class="section">
      <h2 class="section-title"><i class="fas fa-laptop-code"></i> Featured Projects</h2>
      <div class="projects-grid">
        <a href="https://aegix.global/" class="project-card card-glass animate-fade-up" style="--delay: 0ms" target="_blank" rel="noopener noreferrer">
          <div class="project-icon-wrap"><i class="fas fa-shield-alt"></i></div>
          <div class="project-info">
            <h3>Aegix Security <i class="fas fa-external-link-alt"></i></h3>
            <p>Event-driven emergency response platform.</p>
          </div>
        </a>

        <a href="https://eventflo.com/" class="project-card card-glass animate-fade-up" style="--delay: 80ms" target="_blank" rel="noopener noreferrer">
          <div class="project-icon-wrap"><i class="fas fa-video"></i></div>
          <div class="project-info">
            <h3>Eventflo <i class="fas fa-external-link-alt"></i></h3>
            <p>AWS IVS live streaming with real-time director collaboration.</p>
          </div>
        </a>

        <a href="https://launcht.io/" class="project-card card-glass animate-fade-up" style="--delay: 160ms" target="_blank" rel="noopener noreferrer">
          <div class="project-icon-wrap"><i class="fas fa-sync-alt"></i></div>
          <div class="project-info">
            <h3>ACE Tool <i class="fas fa-external-link-alt"></i></h3>
            <p>Multi-tenant Salesforce client sync across global teams.</p>
          </div>
        </a>

        <a href="https://www.gttgrp.com/" class="project-card card-glass animate-fade-up" style="--delay: 240ms" target="_blank" rel="noopener noreferrer">
          <div class="project-icon-wrap"><i class="fas fa-file-alt"></i></div>
          <div class="project-info">
            <h3>Gather <i class="fas fa-external-link-alt"></i></h3>
            <p>US patent analysis with secure auth and network optimisations.</p>
          </div>
        </a>

        <a href="https://energidataportal.dk" class="project-card card-glass animate-fade-up" style="--delay: 320ms" target="_blank" rel="noopener noreferrer">
          <div class="project-icon-wrap"><i class="fas fa-bolt"></i></div>
          <div class="project-info">
            <h3>Energinet Services <i class="fas fa-external-link-alt"></i></h3>
            <p>Danish open-source energy portal backed by CKAN and Flask.</p>
          </div>
        </a>

        <a href="https://play.google.com/store/apps/details?id=com.vijaypathak.com.np.ipochecker" class="project-card card-glass animate-fade-up" style="--delay: 400ms" target="_blank" rel="noopener noreferrer">
          <div class="project-icon-wrap"><i class="fab fa-google-play"></i></div>
          <div class="project-info">
            <h3>IPO Checker <i class="fab fa-google-play"></i></h3>
            <p>Android app for IPO tracking and result notification.</p>
          </div>
        </a>
      </div>
    </section>

    <!-- Education Section -->
    <section class="section">
      <h2 class="section-title"><i class="fas fa-graduation-cap"></i> Education</h2>
      <div class="timeline">
        <div class="timeline-item animate-fade-up" style="--delay: 0ms">
          <div class="timeline-dot"></div>
          <div class="timeline-content card-glass">
            <div class="timeline-header">
              <h3>B.Sc. (Hons) in Computing</h3>
              <span class="timeline-company">London Metropolitan University</span>
              <span class="timeline-date">2019</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Connect -->
    <section class="about-cta-section card-glass animate-fade-up" style="--delay: 80ms">
      <p>Let's connect on <a href="https://linkedin.com/in/hbvj99" target="_blank" rel="noopener noreferrer">LinkedIn</a> or check my code on <a href="https://github.com/hbvj99" target="_blank" rel="noopener noreferrer">GitHub</a>. Feel free to <a href="/contact/">reach out</a> to discuss system architecture, backend engineering, or open source!</p>
    </section>
  </div>
</BaseLayout>

<style>
  .about-hero {
    margin-bottom: 2.5rem;
  }

  .about-hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .about-intro {
    padding: 2rem;
  }

  .about-intro p {
    font-size: 1.1rem;
    margin-bottom: 1.25rem;
    color: var(--text-muted);
  }

  .about-intro p strong {
    color: var(--text);
  }

  .about-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 1.5rem;
  }

  /* Section layouts */
  .section {
    padding: 3rem 0;
    border-top: 1px solid var(--border);
  }

  .section-title {
    font-size: 1.6rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-title i {
    color: var(--primary);
  }

  /* Skills grids */
  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .skills-card {
    padding: 1.5rem;
  }

  .skills-card h4 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .skills-card h4 i {
    color: var(--primary);
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-tag {
    font-size: 0.82rem;
    background-color: var(--bg);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 6px;
    color: var(--text-muted);
    transition: all var(--transition-fast);
  }

  .skill-tag:hover {
    color: var(--text);
    border-color: var(--accent);
    background-color: var(--accent-glow);
  }

  /* Timeline Styles */
  .timeline {
    position: relative;
    padding-left: 1.5rem;
    border-left: 2px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-item {
    position: relative;
  }

  .timeline-dot {
    position: absolute;
    left: calc(-1.5rem - 6px);
    top: 24px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--accent);
    border: 2px solid var(--bg);
    box-shadow: 0 0 10px var(--accent-glow);
  }

  .timeline-content {
    padding: 1.5rem;
  }

  .timeline-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  @media (min-width: 600px) {
    .timeline-header {
      grid-template-columns: auto auto;
      justify-content: space-between;
      align-items: baseline;
    }
  }

  .timeline-header h3 {
    font-size: 1.2rem;
    margin: 0;
  }

  .timeline-company {
    font-weight: 600;
    color: var(--primary);
  }

  @media (min-width: 600px) {
    .timeline-company {
      grid-column: 1;
    }
  }

  .timeline-date {
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  @media (min-width: 600px) {
    .timeline-date {
      grid-column: 2;
      grid-row: 1 / 3;
      justify-self: end;
    }
  }

  .timeline-content p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.6;
  }

  /* Projects styling */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .project-card {
    padding: 1.5rem;
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3),
                0 0 15px var(--primary-glow);
  }

  .project-icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background-color: var(--primary-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    font-size: 1.3rem;
    flex-shrink: 0;
    border: 1px solid rgba(124, 58, 237, 0.2);
  }

  .project-info h3 {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
    color: var(--text);
    transition: color var(--transition-fast);
  }

  .project-card:hover .project-info h3 {
    color: var(--primary);
  }

  .project-info p {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.4;
  }

  /* CTA connect styling */
  .about-cta-section {
    padding: 1.75rem;
    margin-top: 1rem;
    text-align: center;
    font-size: 1.05rem;
    color: var(--text-muted);
  }

  .about-cta-section p {
    margin: 0;
  }

  .about-cta-section a {
    font-weight: 600;
  }
</style>

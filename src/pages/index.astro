---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getPostDate, getPostUrl } from '../utils/post';

// Fetch and sort posts by date descending
const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => getPostDate(b).getTime() - getPostDate(a).getTime());
const recentPosts = sortedPosts.slice(0, 3);
const totalPosts = posts.length;
---

<BaseLayout title="Vijay Pathak" description="Personal webpage of Vijay Pathak, software engineer specializing in scalable backend systems, reliable APIs, and cloud-native services.">
  <div class="container">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-content">
        <h1 class="hero-title glow-title"><span class="hero-highlight">Hi, I'm Vijay</span> <span class="wave">👋</span></h1>
        <p class="hero-subtitle">Software Engineer</p>
        <p class="hero-bio">
          I specialize in designing and building scalable backend systems, reliable APIs, and cloud-native services. Here, I write about systems engineering, cloud automation, and key engineering lessons.
        </p>
        <div class="hero-ctas">
          <a href="/about/" class="btn btn--outline"><i class="fas fa-briefcase"></i> About My Work</a>
          <a href="/contact/" class="btn btn--outline"><i class="far fa-paper-plane"></i> Get In Touch</a>
        </div>
      </div>
    </section>

    <!-- Specialties Grid -->
    <section class="section">
      <h2 class="section-title"><i class="fas fa-cubes"></i> Core Focus & Specialties</h2>
      <div class="specialties-grid">
        <div class="specialty-card card-glass animate-fade-up" style="--delay: 0ms">
          <div class="specialty-icon"><i class="fas fa-sitemap"></i></div>
          <h3>System Design</h3>
          <p>Designing RESTful services, event-driven integrations, and backend APIs for reliable performance.</p>
        </div>
        <div class="specialty-card card-glass animate-fade-up" style="--delay: 100ms">
          <div class="specialty-icon"><i class="fas fa-cloud"></i></div>
          <h3>Cloud & Infrastructure</h3>
          <p>Building cloud automation, serverless pipelines, and containerized deployments across AWS and self-hosted environments.</p>
        </div>
        <div class="specialty-card card-glass animate-fade-up" style="--delay: 200ms">
          <div class="specialty-icon"><i class="fas fa-shield-halved"></i></div>
          <h3>Reliability & Security</h3>
          <p>Improving performance, reliability, and security through caching, load testing, and sound operational practices.</p>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section card-glass animate-fade-up" style="--delay: 0ms">
      <div class="stat-item">
        <span class="stat-number">6+</span>
        <span class="stat-label">Years Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">20+</span>
        <span class="stat-label">Projects Completed</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">{totalPosts}</span>
        <span class="stat-label">Technical Articles</span>
      </div>
    </section>

    <!-- Services Section -->
    <section class="section">
      <h2 class="section-title"><i class="fas fa-briefcase"></i> How I Can Help</h2>
      <div class="services-grid">
        <div class="service-card card-glass animate-fade-up" style="--delay: 0ms">
          <div class="service-icon"><i class="fas fa-server"></i></div>
          <div class="service-info">
            <h3>Backend Development</h3>
            <p>Production-ready REST and GraphQL APIs, microservices, database design, and performance optimization.</p>
          </div>
        </div>
        <div class="service-card card-glass animate-fade-up" style="--delay: 100ms">
          <div class="service-icon"><i class="fas fa-code"></i></div>
          <div class="service-info">
            <h3>Independent Consulting</h3>
            <p>Available for architecture reviews, code audits, system migrations, and technical guidance.</p>
          </div>
        </div>
      </div>
      <div class="services-cta animate-fade-up" style="--delay: 150ms">
        <a href="/contact/" class="btn btn--outline"><i class="far fa-envelope"></i> Discuss a Project</a>
      </div>
    </section>

    <section class="section">
      <div class="section-header-flex">
        <h2 class="section-title"><i class="fas fa-feather-alt"></i> Recent Articles</h2>
      </div>
      <div class="recent-posts-grid">
        {recentPosts.map((post, idx) => {
          const postUrl = getPostUrl(post);
          const pubDate = getPostDate(post).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          });

          return (
            <article class="post-summary-card card-glass animate-fade-up" style={`--delay: ${idx * 80}ms`}>
              <span class="post-summary-date"><i class="far fa-calendar-alt"></i> {pubDate}</span>
              <h3>
                <a href={postUrl}>{post.data.title}</a>
              </h3>
              {post.data.excerpt && (
                <p class="post-summary-excerpt">{post.data.excerpt}</p>
              )}
              <a href={postUrl} class="read-more-btn">Read Article <i class="fas fa-chevron-right"></i></a>
            </article>
          );
        })}
      </div>
      <div class="view-all-container">
        <a href="/posts/" class="btn btn--outline">View All Articles <i class="fas fa-arrow-right"></i></a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Hero Styles */
  .hero-section {
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-start;
    gap: 2.5rem;
    padding: 2rem 0 3.5rem 0;
  }

  @media (min-width: 768px) {
    .hero-section {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
    }
  }

  .hero-content {
    flex: 1;
    text-align: left;
  }

  .hero-title {
    font-size: 2.8rem;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-family: var(--font-title);
  }

  .hero-bio {
    font-size: 1.1rem;
    line-height: 1.65;
    margin-bottom: 2.25rem;
    color: var(--text-muted);
    max-width: 680px;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: flex-start;
    flex-wrap: wrap;
  }



  /* Section Styling */
  .section {
    padding: 3rem 0;
    border-top: 1px solid var(--border);
  }

  .section-title {
    font-size: 1.6rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-title i {
    color: var(--primary);
  }

  /* Specialties Grid */
  .specialties-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .specialties-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .specialty-card {
    padding: 1.75rem;
  }

  .specialty-icon {
    font-size: 1.8rem;
    color: var(--primary);
    margin-bottom: 1.25rem;
  }

  .specialty-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.75rem;
  }

  .specialty-card p {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin: 0;
    line-height: 1.5;
  }

  /* Stats Section */
  .stats-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    margin: 1.5rem 0;
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .stats-section {
      flex-direction: row;
      justify-content: space-around;
      gap: 0;
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: 2.2rem;
    font-weight: 800;
    font-family: var(--font-title);
    background: linear-gradient(135deg, var(--accent) 0%, var(--primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .stat-divider {
    display: none;
    width: 1px;
    height: 40px;
    background-color: var(--border);
  }

  @media (min-width: 768px) {
    .stat-divider {
      display: block;
    }
  }

  /* Services Styles */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .service-card {
    padding: 1.75rem;
    display: flex;
    gap: 1.25rem;
  }

  .service-icon {
    font-size: 1.8rem;
    color: var(--primary);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .service-info h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .service-info p {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin: 0;
  }

  .services-cta {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

  /* Recent Posts list */
  .section-header-flex {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }

  .view-all-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color var(--transition-fast);
  }

  .view-all-link:hover {
    color: var(--accent-hover);
  }

  .recent-posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-summary-card {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .post-summary-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .post-summary-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-summary-card h3 a {
    color: var(--text);
    transition: color var(--transition-fast);
  }

  .post-summary-card h3 a:hover {
    color: var(--primary);
  }

  .post-summary-excerpt {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0 0 1.25rem 0;
    line-height: 1.6;
  }

  .read-more-btn {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--primary);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all var(--transition-fast);
  }

  .read-more-btn:hover {
    color: var(--primary-hover);
    transform: translateX(4px);
  }

  .hero-highlight {
    color: var(--primary) !important;
  }

  .view-all-container {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 2.5rem 0 1rem 0;
    width: 100%;
  }
</style>

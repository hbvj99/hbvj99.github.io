---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found - Vijay Pathak" description="The page you are looking for does not exist.">
  <div class="container error-container animate-fade-up">
    <div class="error-card card-glass">
      <div class="error-icon"><i class="fas fa-compass-drafting"></i></div>
      <h1 class="error-code">404</h1>
      <h2 class="error-msg">Page Not Found</h2>
      <p class="error-desc">The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.</p>
      <div class="error-cta">
        <a href="/" class="btn btn--primary"><i class="fas fa-home"></i> Back to Homepage</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .error-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 3rem 1.5rem;
    min-height: calc(100vh - 250px);
  }

  .error-card {
    padding: 3.5rem 2.5rem;
    text-align: center;
    max-width: 500px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .error-icon {
    font-size: 3rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
    animation: rotate 6s infinite linear;
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .error-code {
    font-size: 5rem;
    font-weight: 900;
    line-height: 1;
    margin: 0 0 0.5rem 0;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -2px;
  }

  .error-msg {
    font-size: 1.6rem;
    margin: 0 0 1rem 0;
    font-family: var(--font-title);
  }

  .error-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 2rem 0;
  }

  .error-cta {
    width: 100%;
  }

  .error-cta .btn {
    width: 100%;
    justify-content: center;
  }
</style>

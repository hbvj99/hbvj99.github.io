---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getPostDate, getPostUrl } from '../utils/post';

function getPostImage(post: any): string | null {
  if (post.data.teaser) return post.data.teaser;
  if (post.data.image) return post.data.image;
  const imgHtmlMatch = post.body.match(/<img[^>]+src=["']([^"']+)["']/i);
  if (imgHtmlMatch && imgHtmlMatch[1]) {
    return imgHtmlMatch[1];
  }
  const imgMdMatch = post.body.match(/!\[[^\]]*\]\(([^)]+)\)/);
  if (imgMdMatch && imgMdMatch[1]) {
    return imgMdMatch[1];
  }
  return null;
}

interface Props {
  title: string;
  description?: string;
  date: Date | string;
  tags?: string[];
  categories?: string[];
  readTime?: string;
  headings?: { depth: number; slug: string; text: string }[];
  url?: string;
  image?: string;
  teaser?: string;
}

const { title, description, date, tags = [], categories = [], readTime, headings = [], url, image, teaser } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Format canonical URL for Disqus
const pageUrl = url || Astro.url.href;
const disqusIdentifier = pageUrl.replace(/https?:\/\/[^\/]+/, '');

// Related posts calculation
const allPosts = await getCollection('posts');
const currentTags = tags || [];
const currentCategories = categories || [];

const relatedPosts = allPosts
  .filter(p => p.data.title !== title) // Exclude current article
  .map(p => {
    const pTags = p.data.tags || [];
    const pCats = p.data.categories || [];
    const sharedTags = pTags.filter(t => currentTags.includes(t)).length;
    const sharedCats = pCats.filter(c => currentCategories.includes(c)).length;
    return { post: p, score: sharedTags * 2 + sharedCats };
  })
  .filter(item => item.score > 0)
  .sort((a, b) => b.score - a.score || getPostDate(b.post).getTime() - getPostDate(a.post).getTime())
  .slice(0, 6)
  .map(item => item.post);

// Fallback to recent posts if no similar posts found
const displayPosts = relatedPosts.length > 0 
  ? relatedPosts 
  : allPosts
      .filter(p => p.data.title !== title)
      .sort((a, b) => getPostDate(b).getTime() - getPostDate(a).getTime())
      .slice(0, 6);

const currentPost = allPosts.find(p => p.data.title === title);
const postImageSrc = teaser || image || (currentPost ? getPostImage(currentPost) : null);
---

<BaseLayout title={`${title} | Vijay Pathak`} description={description || title} url={pageUrl} isArticle={true} publishedTime={date} image={postImageSrc}>


  <div class="container post-container">
    <article class="post-article">
      <header class="post-header">
        <h1 class="post-title glow-title">{title}</h1>

        <div class="post-header-meta">
          <div class="post-meta">
            <span><i class="far fa-calendar-alt"></i> {formattedDate}</span>
            {readTime && (
              <>
                <span class="meta-separator">|</span>
                <span><i class="far fa-clock"></i> {readTime} min read</span>
              </>
            )}
          </div>
        </div>
      </header>

      <hr class="post-divider" />

      <div class="post-layout-grid">
        <!-- Main Content -->
        <div class="post-content-wrap">
          <div class="markdown-content">
            <slot />
          </div>

          <!-- Bottom Categories & Tags -->
          {(categories.length > 0 || tags.length > 0) && (
            <div class="post-footer-meta">
              {tags.length > 0 && (
                <div class="post-meta-row">
                  <span class="meta-label"><i class="fas fa-tags"></i> Tags:</span>
                  <div class="meta-values">
                    {tags.map(tag => (
                      <span class="meta-value-badge">{tag}</span>
                    ))}
                  </div>
                </div>
              )}
              {categories.length > 0 && (
                <div class="post-meta-row">
                  <span class="meta-label"><i class="fas fa-folder"></i> Categories:</span>
                  <div class="meta-values">
                    {categories.map(cat => (
                      <span class="meta-value-badge">{cat}</span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}

          <!-- Share buttons -->
          <div class="share-box card-glass">
            <h4 class="share-title">Share this article</h4>
            <div class="share-links">
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on X" title="Share on X"><i class="fab fa-x-twitter"></i></a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" title="Share on Facebook"><i class="fab fa-facebook-f"></i></a>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn" title="Share on LinkedIn"><i class="fab fa-linkedin-in"></i></a>
            <a href={`https://www.reddit.com/submit?url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on Reddit" title="Share on Reddit"><i class="fab fa-reddit-alien"></i></a>
            <button id="share-copy-btn" aria-label="Copy link" title="Copy link"><i class="fas fa-link"></i></button>
          </div>
          </div>

          <!-- Disqus Comments -->
          <div class="comments-section card-glass">
            <h3 class="comments-title"><i class="far fa-comments"></i> Discussions</h3>
            <div id="disqus_thread"></div>
          </div>

          <!-- Similar Articles -->
          {displayPosts.length > 0 && (
            <div class="related-posts-section">
              <h3 class="related-title"><i class="fas fa-link"></i> Similar Articles</h3>
              <div class="related-slider-wrap">
                <button class="slider-btn slider-btn--left" id="slider-prev" aria-label="Scroll left">
                  <i class="fas fa-chevron-left"></i>
                </button>
                <div class="related-posts-grid">
                  {displayPosts.map(p => {
                    const url = getPostUrl(p);
                    const dateStr = getPostDate(p).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    });
                    const imgSrc = getPostImage(p);
                    return (
                      <div class="related-post-card card-glass animate-fade-up">
                        {imgSrc && (
                          <img src={imgSrc} alt="" class="related-post-img" loading="lazy" />
                        )}
                        <span class="related-post-date"><i class="far fa-calendar-alt"></i> {dateStr}</span>
                        <h4><a href={url}>{p.data.title}</a></h4>
                        {p.data.excerpt && <p>{p.data.excerpt}</p>}
                      </div>
                    );
                  })}
                </div>
                <button class="slider-btn slider-btn--right" id="slider-next" aria-label="Scroll right">
                  <i class="fas fa-chevron-right"></i>
                </button>
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar / Table of Contents -->
        {headings && headings.filter(h => h.depth <= 3).length > 0 && (
          <aside class="post-sidebar">
            <div class="toc-wrap card-glass">
              <h4 class="toc-title"><i class="fas fa-list-ul"></i> On this page</h4>
              <nav class="toc-nav">
                <ul>
                  {headings.filter(h => h.depth <= 3).map(h => (
                    <li class={`toc-item depth-${h.depth}`}>
                      <a href={`#${h.slug}`}>{h.text}</a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>
        )}
      </div>
    </article>

    <!-- Bottom Navigation -->
    <div class="post-footer-nav">
      <a href="/posts/" class="btn btn--outline"><i class="fas fa-arrow-left"></i> Back to Articles</a>
    </div>
  </div>
</BaseLayout>



<!-- Share Copy Link Script -->
<script>
  (function() {
    const shareCopyBtn = document.getElementById('share-copy-btn');
    if (shareCopyBtn) {
      shareCopyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          shareCopyBtn.innerHTML = '<i class="fas fa-check"></i>';
          setTimeout(() => {
            shareCopyBtn.innerHTML = '<i class="fas fa-link"></i>';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy link: ', err);
        }
      });
    }
  })();
</script>

<!-- Code Copier Script -->
<script>
  (function() {
    const codeBlocks = document.querySelectorAll('.markdown-content pre');
    codeBlocks.forEach(block => {
      // Create copy button
      const button = document.createElement('button');
      button.className = 'copy-code-btn';
      button.innerHTML = '<i class="far fa-copy"></i>';
      button.setAttribute('aria-label', 'Copy code');
      button.setAttribute('title', 'Copy code');
      
      // Ensure block is relative positioned
      block.style.position = 'relative';
      block.appendChild(button);
      
      button.addEventListener('click', async () => {
        const code = block.querySelector('code');
        if (!code) return;
        
        try {
          await navigator.clipboard.writeText(code.innerText);
          button.innerHTML = '<i class="fas fa-check"></i>';
          button.classList.add('copied');
          
          setTimeout(() => {
            button.innerHTML = '<i class="far fa-copy"></i>';
            button.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      });
    });
  })();
</script>

<!-- Disqus Configuration Script -->
<script is:inline define:vars={{ pageUrl, disqusIdentifier }}>
  var disqus_config = function () {
    this.page.url = pageUrl;
    this.page.identifier = disqusIdentifier;
  };
  (function() {
    var d = document, s = d.createElement('script');
    s.src = 'https://vijaypathak.disqus.com/embed.js';
    s.setAttribute('data-timestamp', +new Date());
    (d.head || d.body).appendChild(s);
  })();
</script>

<!-- Table of Contents Scroll-Spy Script -->
<script>
  (function() {
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -60% 0px',
      threshold: 0
    };

    const activeIds = new Set();

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const id = entry.target.getAttribute('id');
        if (!id) return;

        if (entry.isIntersecting) {
          activeIds.add(id);
        } else {
          activeIds.delete(id);
        }
      });

      const headings = Array.from(document.querySelectorAll('.markdown-content h1, .markdown-content h2, .markdown-content h3'));
      let currentActiveId = null;

      for (const heading of headings) {
        const id = heading.getAttribute('id');
        if (id && activeIds.has(id)) {
          currentActiveId = id;
          break;
        }
      }

      if (!currentActiveId) {
        const scrollPosition = window.scrollY || document.documentElement.scrollTop;
        for (let i = headings.length - 1; i >= 0; i--) {
          const heading = headings[i];
          const rect = heading.getBoundingClientRect();
          const topPosition = rect.top + scrollPosition;
          if (topPosition < scrollPosition + 200) {
            currentActiveId = heading.getAttribute('id');
            break;
          }
        }
      }

      document.querySelectorAll('.toc-item a').forEach(link => {
        const href = link.getAttribute('href');
        if (href === `#${currentActiveId}`) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    }, observerOptions);

    const headings = document.querySelectorAll('.markdown-content h1, .markdown-content h2, .markdown-content h3');
    headings.forEach(heading => observer.observe(heading));
  })();
</script>

<!-- Similar Articles Slider Navigation Script -->
<script>
  (function() {
    const prevBtn = document.getElementById('slider-prev');
    const nextBtn = document.getElementById('slider-next');
    const grid = document.querySelector('.related-posts-grid');
    if (!prevBtn || !nextBtn || !grid) return;

    prevBtn.addEventListener('click', () => {
      grid.scrollBy({ left: -300, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      grid.scrollBy({ left: 300, behavior: 'smooth' });
    });

    function updateButtons() {
      const scrollLeft = grid.scrollLeft;
      const maxScroll = grid.scrollWidth - grid.clientWidth;
      
      if (scrollLeft <= 5) {
        prevBtn.style.opacity = '0';
        prevBtn.style.pointerEvents = 'none';
      } else {
        prevBtn.style.opacity = '1';
        prevBtn.style.pointerEvents = 'auto';
      }

      if (scrollLeft >= maxScroll - 5) {
        nextBtn.style.opacity = '0';
        nextBtn.style.pointerEvents = 'none';
      } else {
        nextBtn.style.opacity = '1';
        nextBtn.style.pointerEvents = 'auto';
      }
    }

    grid.addEventListener('scroll', updateButtons);
    setTimeout(updateButtons, 100);
    window.addEventListener('resize', updateButtons);
  })();
</script>

